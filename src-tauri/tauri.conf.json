{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "plauzible",
  "version": "1.1.1",
  "identifier": "com.plauzible.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "plauzible",
        "width": 1024,
        "height": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../db/plauzible_template.db": "db/plauzible_template.db"
    }
  }
}
